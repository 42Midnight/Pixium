{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "outDir": "electron-dist",
    "rootDir": "electron",
    "declaration": false,
    "lib": ["ES2020"]
  },
  "include": ["electron/**/*.ts"],
  "exclude": ["electron/main.js"]
}
